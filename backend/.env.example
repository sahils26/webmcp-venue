# Copy to .env and fill in. Local dev defaults to SQLite when DATABASE_URL is unset.

# Neon Postgres connection string (production). Example:
# DATABASE_URL=postgresql+psycopg2://user:pass@ep-xxx.eu-central-1.aws.neon.tech/venuedb?sslmode=require
DATABASE_URL=

# Comma-separated list of allowed CORS origins (the venue-website dev server + prod URL).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://localhost:5173,https://127.0.0.1:5173

# App environment label (development | production).
ENVIRONMENT=development

# Required as X-Admin-API-Key when listing quote requests.
# Change this value outside local demo environments.
ADMIN_API_KEY=local-demo-admin
